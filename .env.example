# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env a git.

# Base de datos TiDB Cloud
DB_HOST=
DB_PORT=4000
DB_USER=
DB_PASSWORD=
DB_NAME_TUNICHE=bodega_tuniche_real
DB_NAME_PUQUILLAY=bodega_puquillay_real

# Seguridad Flask (genera una clave aleatoria larga)
SECRET_KEY=cambia_esto_por_una_clave_aleatoria_muy_larga

# Usuarios del sistema (formato: usuario:clave,otro:clave)
# Ejemplo: LOGIN_USERS=bodega:clave_operario,admin:clave_admin
LOGIN_USERS=bodega:cambiar,admin:cambiar

# Solo para desarrollo local (0 = produccion, 1 = debug)
FLASK_DEBUG=0
